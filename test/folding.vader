
" Helper: create a markdown buffer with folding enabled
" Each test creates its own buffer and cleans up after.

" ---------------------------------------------------------------------------
" Basic header levels
" ---------------------------------------------------------------------------

Execute (h1 starts a level-1 fold):
  new
  call setline(1, ['# Heading 1', 'Some text'])
  setlocal foldmethod=expr foldexpr=markdownfold#foldexpr()
  normal! zx
  AssertEqual 1, foldlevel(1), 'h1 line should be fold level 1'
  AssertEqual 1, foldlevel(2), 'text under h1 should be fold level 1'
  bdelete!

Execute (h2 starts a level-2 fold):
  new
  call setline(1, ['## Heading 2', 'Some text'])
  setlocal foldmethod=expr foldexpr=markdownfold#foldexpr()
  normal! zx
  AssertEqual 2, foldlevel(1), 'h2 line should be fold level 2'
  AssertEqual 2, foldlevel(2), 'text under h2 should be fold level 2'
  bdelete!

Execute (h3 starts a level-3 fold):
  new
  call setline(1, ['### Heading 3', 'Some text'])
  setlocal foldmethod=expr foldexpr=markdownfold#foldexpr()
  normal! zx
  AssertEqual 3, foldlevel(1), 'h3 line should be fold level 3'
  AssertEqual 3, foldlevel(2), 'text under h3 should be fold level 3'
  bdelete!

" ---------------------------------------------------------------------------
" Nested headers
" ---------------------------------------------------------------------------

Execute (nested headers create nested folds):
  new
  call setline(1, ['# Top', 'intro', '## Sub', 'detail', '### SubSub', 'more detail'])
  setlocal foldmethod=expr foldexpr=markdownfold#foldexpr()
  normal! zx
  AssertEqual 1, foldlevel(1), 'h1 should be level 1'
  AssertEqual 1, foldlevel(2), 'text under h1 should be level 1'
  AssertEqual 2, foldlevel(3), 'h2 should be level 2'
  AssertEqual 2, foldlevel(4), 'text under h2 should be level 2'
  AssertEqual 3, foldlevel(5), 'h3 should be level 3'
  AssertEqual 3, foldlevel(6), 'text under h3 should be level 3'
  bdelete!

" ---------------------------------------------------------------------------
" Sibling headers
" ---------------------------------------------------------------------------

Execute (sibling headers at same level create separate folds):
  new
  call setline(1, ['## First', 'aaa', '## Second', 'bbb'])
  setlocal foldmethod=expr foldexpr=markdownfold#foldexpr()
  normal! zx
  AssertEqual 2, foldlevel(1), 'first h2 should be level 2'
  AssertEqual 2, foldlevel(2), 'text under first h2 should be level 2'
  AssertEqual 2, foldlevel(3), 'second h2 should be level 2'
  AssertEqual 2, foldlevel(4), 'text under second h2 should be level 2'
  bdelete!

" ---------------------------------------------------------------------------
" Text before any header
" ---------------------------------------------------------------------------

Execute (text before any header has fold level 0):
  new
  call setline(1, ['Some preamble', 'Another line', '# First heading', 'body'])
  setlocal foldmethod=expr foldexpr=markdownfold#foldexpr()
  normal! zx
  AssertEqual 0, foldlevel(1), 'preamble should be level 0'
  AssertEqual 0, foldlevel(2), 'preamble line 2 should be level 0'
  AssertEqual 1, foldlevel(3), 'h1 should be level 1'
  AssertEqual 1, foldlevel(4), 'body should be level 1'
  bdelete!

" ---------------------------------------------------------------------------
" Empty lines preserve fold level
" ---------------------------------------------------------------------------

Execute (empty lines keep the surrounding fold level):
  new
  call setline(1, ['## Section', 'text', '', 'more text'])
  setlocal foldmethod=expr foldexpr=markdownfold#foldexpr()
  normal! zx
  AssertEqual 2, foldlevel(2), 'text should be level 2'
  AssertEqual 2, foldlevel(3), 'blank line should be level 2'
  AssertEqual 2, foldlevel(4), 'text after blank should be level 2'
  bdelete!

" ---------------------------------------------------------------------------
" Deep headers (h4-h6)
" ---------------------------------------------------------------------------

Execute (h4 through h6 produce correct levels):
  new
  call setline(1, ['#### H4', 'text4', '##### H5', 'text5', '###### H6', 'text6'])
  setlocal foldmethod=expr foldexpr=markdownfold#foldexpr()
  normal! zx
  AssertEqual 4, foldlevel(1), 'h4 should be level 4'
  AssertEqual 4, foldlevel(2), 'text under h4 should be level 4'
  AssertEqual 5, foldlevel(3), 'h5 should be level 5'
  AssertEqual 5, foldlevel(4), 'text under h5 should be level 5'
  AssertEqual 6, foldlevel(5), 'h6 should be level 6'
  AssertEqual 6, foldlevel(6), 'text under h6 should be level 6'
  bdelete!

" ---------------------------------------------------------------------------
" Non-header lines starting with #
" ---------------------------------------------------------------------------

Execute (indented # is not a header):
  new
  call setline(1, ['## Real header', 'body', ' # indented hash'])
  setlocal foldmethod=expr foldexpr=markdownfold#foldexpr()
  normal! zx
  AssertEqual 2, foldlevel(3), 'indented # should not start a new fold'
  bdelete!

" ---------------------------------------------------------------------------
" Ascending back to higher-level header
" ---------------------------------------------------------------------------

Execute (going from h3 back to h1 closes inner folds):
  new
  call setline(1, ['# Part 1', '### Deep', 'detail', '# Part 2', 'new section'])
  setlocal foldmethod=expr foldexpr=markdownfold#foldexpr()
  normal! zx
  AssertEqual 1, foldlevel(1), 'first h1 should be level 1'
  AssertEqual 3, foldlevel(2), 'h3 should be level 3'
  AssertEqual 3, foldlevel(3), 'text under h3 should be level 3'
  AssertEqual 1, foldlevel(4), 'second h1 should be level 1'
  AssertEqual 1, foldlevel(5), 'text under second h1 should be level 1'
  bdelete!

" ---------------------------------------------------------------------------
" Single line document
" ---------------------------------------------------------------------------

Execute (single header line with no body):
  new
  call setline(1, ['# Only header'])
  setlocal foldmethod=expr foldexpr=markdownfold#foldexpr()
  normal! zx
  AssertEqual 1, foldlevel(1), 'lone h1 should be level 1'
  bdelete!

" ---------------------------------------------------------------------------
" Empty document
" ---------------------------------------------------------------------------

Execute (empty document has no folds):
  new
  call setline(1, [''])
  setlocal foldmethod=expr foldexpr=markdownfold#foldexpr()
  normal! zx
  AssertEqual 0, foldlevel(1), 'empty line should be level 0'
  bdelete!

" ---------------------------------------------------------------------------
" Fenced code blocks
" ---------------------------------------------------------------------------

Execute (code block creates a nested fold under a header):
  new
  call setline(1, ['## Section', 'text', '```python', 'code line 1', 'code line 2', '```', 'after'])
  setlocal foldmethod=expr foldexpr=markdownfold#foldexpr()
  normal! zx
  AssertEqual 2, foldlevel(1), 'header should be level 2'
  AssertEqual 2, foldlevel(2), 'text should be level 2'
  AssertEqual 3, foldlevel(3), 'opening fence should be level 3'
  AssertEqual 3, foldlevel(4), 'code line 1 should be level 3'
  AssertEqual 3, foldlevel(5), 'code line 2 should be level 3'
  AssertEqual 3, foldlevel(6), 'closing fence should be level 3'
  AssertEqual 2, foldlevel(7), 'after should be level 2'
  bdelete!

Execute (code block before any header):
  new
  call setline(1, ['some text', '```', 'code', '```', 'after'])
  setlocal foldmethod=expr foldexpr=markdownfold#foldexpr()
  normal! zx
  AssertEqual 0, foldlevel(1), 'text before code block should be level 0'
  AssertEqual 1, foldlevel(2), 'opening fence should be level 1'
  AssertEqual 1, foldlevel(3), 'code should be level 1'
  AssertEqual 1, foldlevel(4), 'closing fence should be level 1'
  AssertEqual 0, foldlevel(5), 'after should be level 0'
  bdelete!

Execute (# inside code block does not start a header fold):
  new
  call setline(1, ['## Config', '```', '# this is a comment', '```', 'after block'])
  setlocal foldmethod=expr foldexpr=markdownfold#foldexpr()
  normal! zx
  AssertEqual 2, foldlevel(1), 'h2 should be level 2'
  AssertEqual 3, foldlevel(2), 'opening fence should be level 3'
  AssertEqual 3, foldlevel(3), '# inside code block should be level 3 (not a header)'
  AssertEqual 3, foldlevel(4), 'closing fence should be level 3'
  AssertEqual 2, foldlevel(5), 'after block should be level 2'
  bdelete!

Execute (two code blocks create separate folds):
  new
  call setline(1, ['# Top', '```', 'a', '```', 'gap', '```', 'b', '```', 'end'])
  setlocal foldmethod=expr foldexpr=markdownfold#foldexpr()
  normal! zx
  AssertEqual 2, foldlevel(2), 'first opening fence should be level 2'
  AssertEqual 2, foldlevel(3), 'first code should be level 2'
  AssertEqual 2, foldlevel(4), 'first closing fence should be level 2'
  AssertEqual 1, foldlevel(5), 'gap should be level 1'
  AssertEqual 2, foldlevel(6), 'second opening fence should be level 2'
  AssertEqual 2, foldlevel(7), 'second code should be level 2'
  AssertEqual 2, foldlevel(8), 'second closing fence should be level 2'
  AssertEqual 1, foldlevel(9), 'end should be level 1'
  bdelete!

" ---------------------------------------------------------------------------
" Quote blocks
" ---------------------------------------------------------------------------

Execute (quote block creates a nested fold under a header):
  new
  call setline(1, ['## Section', 'text', '> quote 1', '> quote 2', '> quote 3', 'after'])
  setlocal foldmethod=expr foldexpr=markdownfold#foldexpr()
  normal! zx
  AssertEqual 2, foldlevel(1), 'header should be level 2'
  AssertEqual 2, foldlevel(2), 'text should be level 2'
  AssertEqual 3, foldlevel(3), 'first quote line should be level 3'
  AssertEqual 3, foldlevel(4), 'second quote line should be level 3'
  AssertEqual 3, foldlevel(5), 'third quote line should be level 3'
  AssertEqual 2, foldlevel(6), 'after should be level 2'
  bdelete!

Execute (quote block before any header):
  new
  call setline(1, ['text', '> quoted 1', '> quoted 2', 'after'])
  setlocal foldmethod=expr foldexpr=markdownfold#foldexpr()
  normal! zx
  AssertEqual 0, foldlevel(1), 'text should be level 0'
  AssertEqual 1, foldlevel(2), 'first quote line should be level 1'
  AssertEqual 1, foldlevel(3), 'second quote line should be level 1'
  AssertEqual 0, foldlevel(4), 'after should be level 0'
  bdelete!

Execute (single-line quote does not create a fold):
  new
  call setline(1, ['## Section', 'text', '> single quote', 'after'])
  setlocal foldmethod=expr foldexpr=markdownfold#foldexpr()
  normal! zx
  AssertEqual 2, foldlevel(3), 'single quote should stay at header level'
  AssertEqual 2, foldlevel(4), 'after single quote should stay at header level'
  bdelete!

Execute (two quote blocks separated by text create separate folds):
  new
  call setline(1, ['# Top', '> q1a', '> q1b', 'gap', '> q2a', '> q2b', 'end'])
  setlocal foldmethod=expr foldexpr=markdownfold#foldexpr()
  normal! zx
  AssertEqual 2, foldlevel(2), 'first quote block line 1 should be level 2'
  AssertEqual 2, foldlevel(3), 'first quote block line 2 should be level 2'
  AssertEqual 1, foldlevel(4), 'gap should be level 1'
  AssertEqual 2, foldlevel(5), 'second quote block line 1 should be level 2'
  AssertEqual 2, foldlevel(6), 'second quote block line 2 should be level 2'
  AssertEqual 1, foldlevel(7), 'end should be level 1'
  bdelete!

Execute (> inside code block is not a quote):
  new
  call setline(1, ['# Top', '```', '> not a quote', '```', 'after'])
  setlocal foldmethod=expr foldexpr=markdownfold#foldexpr()
  normal! zx
  AssertEqual 2, foldlevel(2), 'opening fence should be level 2'
  AssertEqual 2, foldlevel(3), '> inside code should be level 2 (not a quote)'
  AssertEqual 2, foldlevel(4), 'closing fence should be level 2'
  AssertEqual 1, foldlevel(5), 'after should be level 1'
  bdelete!

" ---------------------------------------------------------------------------
" BufEnter reapplies fold settings when switching buffers
" ---------------------------------------------------------------------------

Execute (folding works after :b switch to markdown buffer):
  " Create a markdown buffer and trigger ftplugin via filetype
  new
  file test_md.md
  setlocal filetype=markdown
  call setline(1, ['# Hello', 'world'])
  let g:test_md_buf = bufnr('%')

  " Create a second (non-markdown) buffer and switch to it
  set hidden
  enew
  file other.txt
  setlocal filetype=text
  call setline(1, ['plain text'])

  " Switch back to the markdown buffer with :b — this fires BufEnter
  execute 'buffer ' . g:test_md_buf
  normal! zx

  AssertEqual 'expr', &foldmethod, 'foldmethod should be expr after :b switch'
  AssertEqual 'markdownfold#foldexpr()', &foldexpr, 'foldexpr should be set after :b switch'
  AssertEqual 1, foldlevel(1), 'h1 should be level 1 after :b switch'
  AssertEqual 1, foldlevel(2), 'text should be level 1 after :b switch'

  bdelete!
  bdelete!

Execute (folding works after :b switch when md buffer is also in another tab):
  " Simulate vim -p: markdown buffer visible in a tab
  new
  file tabbed_md.md
  setlocal filetype=markdown
  call setline(1, ['## Section', 'content', '### Sub', 'detail'])
  let g:test_md_buf2 = bufnr('%')

  " Open it in a second tab (so it's displayed in two windows)
  tab split

  " In the second tab, switch to a plain buffer
  enew
  file plain.txt
  setlocal filetype=text
  call setline(1, ['not markdown'])

  " Now switch back to the md buffer in this tab via :b
  set hidden
  execute 'buffer ' . g:test_md_buf2
  normal! zx

  AssertEqual 'expr', &foldmethod, 'foldmethod should be expr after tab :b switch'
  AssertEqual 'markdownfold#foldexpr()', &foldexpr, 'foldexpr should be set after tab :b switch'
  AssertEqual 2, foldlevel(1), 'h2 should be level 2 after tab :b switch'
  AssertEqual 3, foldlevel(3), 'h3 should be level 3 after tab :b switch'

  " Clean up both tabs
  tabclose
  bdelete!
  bdelete!
